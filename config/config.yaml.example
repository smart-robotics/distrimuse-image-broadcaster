cameras:
  - name: side_view
    rtsp_url: "rtsp://user:password@10.0.0.1:554/cam/realmonitor?channel=1&subtype=1"
  - name: back_view
    rtsp_url: "rtsp://user:password@10.0.0.2:554/cam/realmonitor?channel=1&subtype=1"
  - name: front_view
    rtsp_url: "rtsp://user:password@10.0.0.3:554/cam/realmonitor?channel=1&subtype=1"

# Target publish rate (frames per second) for broadcasting camera frames to ROS topics.
# Can be overridden at runtime with: pixi run broadcast --fps <value>
fps: 25

# ROS topic pattern for each camera. {name} is replaced by the camera's name above.
# e.g. with name "front_view" this becomes "/camera/front_view/image_raw"
topic_template: "/camera/{name}/image_raw"
